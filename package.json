{
  "name": "@kiwiproject/vue-dynamic-property-provider",
  "version": "0.0.0-semantically-released",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiwiproject/vue-dynamic-property-provider.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "main": "./dist/vue-dynamic-property-provider.cjs.js",
  "module": "./dist/vue-dynamic-property-provider.es.js",
  "exports": {
    ".": {
      "import": "./dist/vue-dynamic-property-provider.es.js",
      "require": "./dist/vue-dynamic-property-provider.cjs.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --p ./tsconfig-build.json && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write src/"
  },
  "peerDependencies": {
    "vue": "3.5.34"
  },
  "devDependencies": {
    "semantic-release": "25.0.3",
    "@tailwindcss/vite": "4.3.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "ts-jest": "29.4.10",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vue": "3.5.34",
    "vue-tsc": "3.3.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.2"
  }
